<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simposons.personajes.PersonajeController" >

<left>
    <VBox spacing="15.0" styleClass="sidebar" prefWidth="280.0">
        <children>
            <VBox spacing="10.0" alignment="CENTER">
                <children>
                    <Label text="🍩" styleClass="main-icon" />
                    <Label text="SPRINGFIELD" styleClass="app-title"/>
                    <Label text="personajes" styleClass="app-subtitle"/>
                </children>
                <padding>
                    <Insets top="30.0" bottom="20.0"/>
                </padding>
            </VBox>

            <Separator />

            <VBox spacing="10.0" styleClass="search-section">
                <children>
                    <Label text="Buscar Personaje" styleClass="section-title" />
                    <TextField promptText="Nombre del personaje..." styleClass="search-field"/>
                    <HBox spacing="10.0" alignment="CENTER">
                        <children>
                            <Button text="🔍 Buscar" styleClass="action-button" HBox.hgrow="ALWAYS"/>
                            <Button text=" 🎲 Aleatorio" styleClass="random-button"/>
                        </children>
                    </HBox>
                </children>
                <padding>
                    <Insets left="20.0" right="20.0" />
                </padding>
            </VBox>

            <Separator />

            <VBox>
                <children>
                    <Label text="ℹ️ Informacion" styleClass="section-title" />
                    <Label text="Explora mas de 1182 personajes de los Simpsons" styleClass="info-text" wrapText="true"  />
                </children>
                <padding>
                    <Insets left="20.0" right="20.0" bottom="20.0" />
                </padding>
            </VBox>
        </children>
        <padding>
            <Insets bottom="20.0" />
        </padding>
    </VBox>
</left>

<center>
    <VBox spacing="0.1">
        <children>
            <HBox alignment="CENTER" styleClass="top-bar">
                <children>
                    <Label text="Personajes de Los Simpsons" styleClass="main-title"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="➕ Cargar Más" styleClass="load-button"/>
                </children>
                <padding>
                    <Insets left="30.0" right="30.0" top="20.0" bottom='20.0' />
                </padding>
            </HBox>

            <ScrollPane >
                <content>
                    <FlowPane styleClass="main-scroll" >
                        <padding>
                            <Insets left="30.0" right="30.0" top="30.0" bottom='30.0' />
                        </padding>
                    </FlowPane>
                </content>
            </ScrollPane>
        </children>
    </VBox>
</center>
</BorderPane>