<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml" fx:controller="com.holamundo.SaludoController" >
    <Label text="¿Cómo te llamas?" />
    <TextField fx:id="txtMensaje" prefWidth="300.0" maxWidth="300.0"/>
    <HBox spacing="30" alignment="CENTER">
        <Button text="Enviar" onAction="#mostrarMensaje" />
        <Button text="Limpiar" onAction="#limpiar" />
    </HBox>
</VBox>